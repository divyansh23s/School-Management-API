{
  "info": {
    "name": "School Management API",
    "description": "API collection for adding and parsing school locations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Greenwood High\",\n  \"address\": \"123 Park Avenue\",\n  \"latitude\": 12.9715,\n  \"longitude\": 77.5946\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/addSchool",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "api",
            "addSchool"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/listSchools?latitude=12.9700&longitude=77.5900",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "api",
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "12.9700"
            },
            {
              "key": "longitude",
              "value": "77.5900"
            }
          ]
        }
      },
      "response": []
    }
  ]
}
